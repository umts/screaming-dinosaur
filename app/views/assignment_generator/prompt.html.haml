= render layout: 'layouts/roster', locals: { roster: @assignment_generator.roster, nav_item: 'assignments' } do
  .card
    .card-header
      Assignment Generator
    .card-body
      = form_with model: @assignment_generator,
                  url: generate_roster_assignments_path(@assignment_generator.roster) do |f|
        .row.g-3
          .mb-3.col-md
            = f.label :group, class: 'form-label'
            = f.text_field :group, required: true, class: 'form-control'
        .mb-3
          = f.label :user_id, class: 'form-label'
          = f.collection_select :user_id,
                                @assignment_generator.roster.users.order(:first_name, :last_name), :id, :full_name,
                                {}, required: true, class: 'form-select', 'data-controller': 'tom-select'
        .row.g-3
          .mb-3.col-md
            = f.label :start_date, class: 'form-label'
            = f.date_field :start_date, required: true, class: 'form-control'
          .mb-3.col-md
            = f.label :end_date, class: 'form-label'
            = f.date_field :end_date, required: true, class: 'form-control'
        .row.g-3
          .mb-3.col-md
            = f.label :weekdays, class: 'form-label'
            - Date::DAYNAMES.each do |day|
              .form-check
                = f.check_box :weekdays, { multiple: true, class: 'form-check-input' }, day, nil
                = f.label "weekdays_#{day}", day, class: 'form-check-label'
          .mb-3.col-md
            = f.label :end_time, class: 'form-label'
            = f.time_field :end_time, required: true, class: 'form-control'
        .d-grid
          = f.button type: :submit, class: 'btn btn-outline-primary' do
            %i.fa-solid.fa-check
            Generate
