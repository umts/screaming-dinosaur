Hello <%= @recipient.first_name %>,

This is an automatically generated reminder of your upcoming on-call assignments:

<% @assignments.group_by(&:roster).each do |roster, assignments| -%>
<%= roster.name %>:
<% assignments.each do |assignment| -%>
  - <%= l assignment.start_datetime, format: :named %> to <%= l assignment.end_datetime, format: :named %>
<% end -%>

<% end -%>
