= render layout: 'layouts/resource', locals: { heading: 'Register' } do
  .card.mb-3
    .card-header
      New User
    .card-body
      - if session[:upn].present?
        .mb-3
          %label.form-label{ for: 'upn' } Microsoft account
          %input#upn.form-control{ type: 'text', value: session[:upn], disabled: true }
      = form_with model: @user, html: { id: 'user-form' } do |f|
        = render partial: 'fields', object: f
      .row.g-3
        .col.d-grid
          = button_tag type: :submit, form: 'user-form', class: 'btn btn-outline-primary' do
            %i.fa-solid.fa-save
            Save
        .col.d-grid
          = button_to logout_path,
                      class: 'btn btn-outline-secondary',
                      form_class: 'd-grid' do
            %i.fa-solid.fa-times
            Cancel
