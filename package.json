{
  "dependencies": {
    "@csstools/postcss-sass": "*",
    "@fortawesome/fontawesome-free": "*",
    "@fullcalendar/bootstrap5": "*",
    "@fullcalendar/core": "*",
    "@fullcalendar/daygrid": "*",
    "@hotwired/stimulus": "*",
    "@popperjs/core": "*",
    "@rails/ujs": "*",
    "@rollup/plugin-node-resolve": "*",
    "autoprefixer": "*",
    "bootstrap": "*",
    "postcss": "*",
    "postcss-cli": "*",
    "postcss-scss": "*",
    "rollup": "*",
    "tom-select": "*"
  },
  "devDependencies": {
    "@eslint/js": "< 10",
    "eslint": "< 10",
    "eslint-config-google": "*",
    "eslint-formatter-compact": "*",
    "globals": "*",
    "run-pty": "*",
    "stylelint": "*",
    "stylelint-config-standard": "*",
    "stylelint-config-standard-scss": "*"
  },
  "scripts": {
    "build": "rollup ./app/javascript/application.js -o ./app/assets/builds/application.js -c",
