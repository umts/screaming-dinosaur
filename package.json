{
  "dependencies": {
    "@activeadmin/activeadmin": "^4.0.0-beta22",
    "@csstools/postcss-sass": "*",
    "@fortawesome/fontawesome-free": "*",
    "@fullcalendar/bootstrap5": "*",
    "@fullcalendar/core": "*",
    "@fullcalendar/daygrid": "*",
    "@hotwired/stimulus": "*",
    "@popperjs/core": "^2.11.8",
    "@rails/ujs": "*",
    "@rollup/plugin-node-resolve": "*",
    "@tailwindcss/cli": "^4.3.2",
    "autoprefixer": "*",
    "bootstrap": "^5.3.8",
    "postcss": "*",
    "postcss-cli": "< 11",
    "postcss-scss": "*",
    "rollup": "< 4",
    "tailwindcss": "^4.3.2",
    "tom-select": "*"
  },
  "devDependencies": {
    "@eslint/js": "< 9",
    "eslint": "< 9",
    "eslint-config-google": "*",
    "globals": "*",
    "run-pty": "*",
    "stylelint": "< 16",
    "stylelint-config-standard": "< 35",
    "stylelint-config-standard-scss": "< 12"
  },
  "scripts": {
    "build": "rollup ./app/javascript/application.js -o ./app/assets/builds/application.js -c && rollup ./app/javascript/active_admin.js -o ./app/assets/builds/active_admin.js -c",
    "build:css": "postcss ./app/assets/stylesheets/application.scss -o ./app/assets/builds/application.css && tailwindcss -i ./app/assets/stylesheets/active_admin.css -o ./app/assets/builds/active_admin.css --minify",
    "lint": "eslint .",
    "lint:css": "stylelint **/*.css **/*.scss"
  }
}
